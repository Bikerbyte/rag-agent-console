APP_PORT=8080
# Shared PostgreSQL endpoint as seen from the app container.
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5433

POSTGRES_DB=rag_agent
POSTGRES_USER=rag_agent
POSTGRES_PASSWORD=change-me

TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USE_WEBHOOK_MODE=false
TELEGRAM_BOT_WEBHOOK_PATH=/api/telegram/webhook
TELEGRAM_BOT_WEBHOOK_URL=
TELEGRAM_BOT_WEBHOOK_SECRET_TOKEN=
# Leave empty to use the machine/pod name.
APP_RUNTIME_INSTANCE_NAME=
# Role switches: same image can run as web (ingress only) or worker (background jobs only).
# Leave empty to enable everything (single-node mode).
APP_RUNTIME_ENABLE_TELEGRAM_WEBHOOK_INGRESS=
APP_RUNTIME_ENABLE_TELEGRAM_POLLING_WORKER=
APP_RUNTIME_ENABLE_TELEGRAM_UPDATE_QUEUE_WORKER=

# AI provider: Local, OpenAI, or Ollama.
# Local works without API keys and uses deterministic fallback behavior.
AI_PROVIDER=Local
AI_ENABLE_CHAT_GENERATION=false
AI_USE_LOCAL_FALLBACK=true

OPENAI_API_BASE_URL=https://api.openai.com
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

OLLAMA_API_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# RAG vector store (pgvector; the bundled Postgres image ships the extension).
RAG_LOCAL_EMBEDDING_DIMENSIONS=384
RAG_MAX_CHUNKS=5
VECTOR_STORE_CANDIDATE_LIMIT=3000

# Observability: traces/metrics go to a shared grafana/otel-lgtm instance.
# Grafana UI: http://localhost:3000
ENABLE_OPEN_TELEMETRY=true
ENABLE_OPEN_TELEMETRY_CONSOLE_EXPORTER=false
OTEL_OTLP_ENDPOINT=http://host.docker.internal:4317
OPEN_TELEMETRY_SERVICE_NAME=RagAgentConsole

# Optional self-contained demo overlay ports.
DEMO_POSTGRES_PORT=15433
DEMO_GRAFANA_PORT=3300
DEMO_OTLP_GRPC_PORT=14317
