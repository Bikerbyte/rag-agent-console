APP_PORT=8080
POSTGRES_PORT=5432

POSTGRES_DB=security_advisory_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USE_WEBHOOK_MODE=false
TELEGRAM_BOT_WEBHOOK_PATH=/api/telegram/webhook
TELEGRAM_BOT_WEBHOOK_URL=
TELEGRAM_BOT_WEBHOOK_SECRET_TOKEN=
APP_RUNTIME_PROFILE=Standard
APP_RUNTIME_INSTANCE_NAME=vm1
APP_RUNTIME_ENABLE_LEADERSHIP_LEASE=true
APP_RUNTIME_LEASE_DURATION_SECONDS=45
APP_RUNTIME_LEASE_RENEW_INTERVAL_SECONDS=15
APP_RUNTIME_LEASE_ACQUIRE_RETRY_SECONDS=10
# Advanced overrides. Leave empty to follow APP_RUNTIME_PROFILE.
APP_RUNTIME_ENABLE_TELEGRAM_WEBHOOK_INGRESS=
APP_RUNTIME_ENABLE_TELEGRAM_POLLING_WORKER=
APP_RUNTIME_ENABLE_TELEGRAM_UPDATE_QUEUE_WORKER=
APP_RUNTIME_ENABLE_OFFICIAL_DATA_SYNC_WORKER=
APP_RUNTIME_ENABLE_NOTIFICATION_WORKER=

SECURITY_ADVISORIES_ENABLE_CISA_KEV_SOURCE=true
SECURITY_ADVISORIES_ENABLE_NVD_SOURCE=true
SECURITY_ADVISORIES_NVD_LOOKBACK_DAYS=7
SECURITY_ADVISORIES_MAX_NVD_RESULTS_PER_SYNC=100
ENABLE_SECURITY_ADVISORY_PUSH=true
