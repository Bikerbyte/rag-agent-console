ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
ConnectionStrings__DefaultConnection=Host=192.168.0.223;Port=5432;Database=cpbl_telegram_assistant;Username=postgres;Password=change-me

TelegramBot__Enabled=true
TelegramBot__BotToken=
TelegramBot__UseWebhookMode=true
TelegramBot__WebhookPath=/api/telegram/webhook
TelegramBot__WebhookUrl=https://your-public-host.example/api/telegram/webhook
TelegramBot__WebhookSecretToken=replace-with-a-long-secret

AppRuntime__Profile=Standard
AppRuntime__InstanceName=vm-1
AppRuntime__EnableLeadershipLease=true
