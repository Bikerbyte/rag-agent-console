# 多節點擴展節點：可接 webhook、吃 queue，也可透過 lease 接手 scheduled jobs
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://127.0.0.1:5050
ConnectionStrings__DefaultConnection=Host=10.0.0.10;Port=5432;Database=cpbl_telegram_assistant;Username=postgres;Password=change-me

TelegramBot__Enabled=true
TelegramBot__BotToken=
TelegramBot__UseWebhookMode=true
TelegramBot__WebhookPath=/api/telegram/webhook
TelegramBot__WebhookUrl=https://bot.example.com/api/telegram/webhook
TelegramBot__WebhookSecretToken=replace-with-a-long-secret

AppRuntime__Profile=Standard
AppRuntime__InstanceName=vm-scale-1
AppRuntime__EnableLeadershipLease=true
AppRuntime__LeaseDurationSeconds=45
AppRuntime__LeaseRenewIntervalSeconds=15
AppRuntime__LeaseAcquireRetrySeconds=10
