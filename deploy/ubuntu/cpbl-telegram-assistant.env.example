# ASP.NET Core host
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://127.0.0.1:5050

# Database
ConnectionStrings__DefaultConnection=Host=127.0.0.1;Port=5432;Database=cpbl_telegram_assistant;Username=postgres;Password=change-me

# Telegram
TelegramBot__Enabled=true
TelegramBot__BotToken=
TelegramBot__UseWebhookMode=true
TelegramBot__WebhookPath=/api/telegram/webhook
TelegramBot__WebhookUrl=https://your-domain.example/api/telegram/webhook
TelegramBot__WebhookSecretToken=replace-with-a-long-secret

# Runtime node identity
AppRuntime__Profile=Standard
AppRuntime__InstanceName=vm-single
AppRuntime__EnableLeadershipLease=true
AppRuntime__LeaseDurationSeconds=45
AppRuntime__LeaseRenewIntervalSeconds=15
AppRuntime__LeaseAcquireRetrySeconds=10

# Advanced role overrides. Leave commented unless you really need to break away from the profile.
# AppRuntime__EnableTelegramWebhookIngress=true
# AppRuntime__EnableTelegramPollingWorker=false
# AppRuntime__EnableTelegramUpdateQueueWorker=true
# AppRuntime__EnableOfficialDataSyncWorker=true
# AppRuntime__EnableNotificationWorker=true

# Push options
PushNotifications__Enabled=true
PushNotifications__WorkerIntervalSeconds=90
PushNotifications__GameStartLeadMinutes=30
