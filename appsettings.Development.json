  "AppRuntime": {
    "Profile": "Standard",
    "InstanceName": "local-dev",
    "EnableLeadershipLease": true,
    "LeaseDurationSeconds": 45,
    "LeaseRenewIntervalSeconds": 15,
    "LeaseAcquireRetrySeconds": 10
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
