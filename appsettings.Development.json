{
  "DetailedErrors": true,
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "TelegramBot": {
    "Enabled": false,
    "BotToken": "",
    "ApiBaseUrl": "https://api.telegram.org",
    "PollingDelaySeconds": 3,
    "UseWebhookMode": false,
    "WebhookPath": "/api/telegram/webhook",
    "WebhookUrl": "",
    "WebhookSecretToken": ""
  },
  "DataSources": {
