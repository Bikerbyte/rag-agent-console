@page
@model CPBLLineBotCloud.Pages.News.IndexModel
@{
    ViewData["Title"] = "新聞";
}

<section class="page-header">
    <div>
        <p class="eyebrow">新聞資料</p>
        <h1>新聞</h1>
        <p class="page-copy">查看目前已同步的新聞內容</p>
    </div>
    <div class="page-actions">
        <form method="post" asp-page-handler="Sync">
            <button class="btn btn-primary" type="submit">立即同步</button>
        </form>
    </div>
</section>

<section class="panel">
        <div class="panel-header">
            <div class="panel-title-group">
                <span class="section-kicker">新聞列表</span>
                <h2 class="panel-title">已同步新聞</h2>
                <p class="panel-subtitle">確認資料是否正確即可</p>
            </div>
        </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-info">@Model.StatusMessage</div>
    }

    <div class="table-section">
        <table class="table admin-table">
            <thead>
                <tr>
                    <th>發布時間</th>
                    <th>分類</th>
                    <th>標題</th>
                    <th>來源</th>
                    <th>已推播</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.NewsItems.Count == 0)
            {
                <tr>
                    <td colspan="5">
                        <div class="empty-state">
                            <p class="empty-copy">目前還沒有新聞資料</p>
                        </div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var item in Model.NewsItems)
                {
                    <tr>
                        <td>@item.PublishTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@(string.IsNullOrWhiteSpace(item.Category) ? "-" : item.Category)</td>
                        <td>
                            <a class="table-title" href="@item.Url" target="_blank" rel="noreferrer">@item.Title</a>
                        </td>
                        <td>@item.SourceName</td>
                        <td>
                            <span class="status-pill @(item.IsSent ? "is-success" : "is-neutral")">
                                @(item.IsSent ? "是" : "否")
                            </span>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>
