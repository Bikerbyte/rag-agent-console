@page
@model SecurityAdvisoryBot.Pages.Groups.IndexModel
@{
    ViewData["Title"] = "Telegram 訂閱設定";
}

<section class="page-header">
    <div>
        <p class="eyebrow">Notification rules</p>
        <h1>Telegram 訂閱設定</h1>
        <p class="page-copy">管理聊天、弱點推播與關鍵字 watchlist</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info" role="alert">
        @Model.StatusMessage
    </div>
}

<section class="content-grid">
    <article class="panel">
        <div class="panel-header">
            <div class="panel-title-group">
                <span class="section-kicker">編輯</span>
                <h2 class="panel-title">@(Model.IsEditMode ? "編輯聊天" : "新增聊天")</h2>
            </div>

            @if (Model.IsEditMode)
            {
                <div class="page-actions">
                    <form method="post" asp-page-handler="Reset">
                        <button type="submit" class="btn btn-outline-secondary">新增聊天</button>
                    </form>
                </div>
            }
        </div>

        <form method="post" asp-page-handler="Save">
            <input type="hidden" asp-for="Input.TelegramChatSubscriptionId" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="Input.ChatTitle" class="form-label">聊天名稱</label>
                    <input asp-for="Input.ChatTitle" class="form-control" />
                    <span asp-validation-for="Input.ChatTitle" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.ChatId" class="form-label">聊天 ID</label>
                    <input asp-for="Input.ChatId" class="form-control" />
                    <span asp-validation-for="Input.ChatId" class="text-danger"></span>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <div class="form-check mt-2">
                        <input asp-for="Input.EnableAdvisoryPush" class="form-check-input" />
                        <label asp-for="Input.EnableAdvisoryPush" class="form-check-label">啟用弱點推播</label>
                    </div>
                </div>
                <div class="col-md-5">
                    <label asp-for="Input.AdvisoryKeywords" class="form-label">弱點關鍵字</label>
                    <input asp-for="Input.AdvisoryKeywords" class="form-control" placeholder="fortinet, azure, windows" />
                    <span asp-validation-for="Input.AdvisoryKeywords" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Input.MinimumSeverity" class="form-label">最低風險</label>
                    <input asp-for="Input.MinimumSeverity" class="form-control" placeholder="Critical" />
                    <span asp-validation-for="Input.MinimumSeverity" class="text-danger"></span>
                </div>
            </div>

            <p class="form-hint mb-3">
                關鍵字以逗號分隔。沒有設定關鍵字時，系統只推送 Critical 或 CISA KEV 類型的高風險情報。
            </p>

            <button type="submit" class="btn btn-primary">@(Model.IsEditMode ? "儲存變更" : "建立聊天")</button>
        </form>
    </article>

    <article class="panel">
        <div class="panel-header">
            <div class="panel-title-group">
                <span class="section-kicker">說明</span>
                <h2 class="panel-title">使用方式</h2>
                <p class="panel-subtitle">保持規則簡單，避免通知失控</p>
            </div>
        </div>

        <ul class="panel-list">
            <li>聊天 ID 會在 bot 第一次收到訊息時自動建立</li>
            <li>關鍵字會比對 CVE、vendor、product、tags 和摘要內容</li>
            <li>Telegram 也可以用 <code>/subscribe fortinet azure</code> 更新 watchlist</li>
        </ul>
    </article>
</section>

<section class="panel mt-4">
    <div class="panel-header">
        <div class="panel-title-group">
            <span class="section-kicker">清單</span>
            <h2 class="panel-title">已設定聊天</h2>
            <p class="panel-subtitle">目前推播目標一覽</p>
        </div>
    </div>

    <div class="table-section">
        <table class="table admin-table">
            <thead>
                <tr>
                    <th>Chat</th>
                    <th>弱點推播</th>
                    <th>弱點關鍵字</th>
                    <th>最低風險</th>
                    <th>更新時間</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Subscriptions.Count == 0)
            {
                <tr>
                    <td colspan="6">
                        <div class="empty-state">
                            <p class="empty-copy">目前還沒有聊天設定，先讓 bot 收到一則訊息再來建立即可</p>
                        </div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var chat in Model.Subscriptions)
                {
                    <tr>
                        <td>
                            <span class="table-title">@chat.ChatTitle</span>
                            <p class="table-copy">@chat.ChatId</p>
                        </td>
                        <td>
                            <span class="status-pill @(chat.EnableAdvisoryPush ? "is-success" : "is-neutral")">
                                @(chat.EnableAdvisoryPush ? "啟用" : "停用")
                            </span>
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(chat.AdvisoryKeywords) ? "-" : chat.AdvisoryKeywords)</td>
                        <td>@(string.IsNullOrWhiteSpace(chat.MinimumSeverity) ? "-" : chat.MinimumSeverity)</td>
                        <td>@chat.LastUpdatedTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end">
                            <form method="post" asp-page-handler="Edit">
                                <input type="hidden" name="id" value="@chat.TelegramChatSubscriptionId" />
                                <button type="submit" class="btn btn-sm btn-outline-primary">編輯</button>
                            </form>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
