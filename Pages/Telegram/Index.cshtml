@page
@model CPBLLineBotCloud.Pages.Telegram.IndexModel
@{
    ViewData["Title"] = "Telegram";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Admin</p>
        <h1>Telegram bot</h1>
        <p class="page-copy">Check whether the bot is configured, learn the small set of core commands, and verify that chats are being recorded correctly.</p>
    </div>
</div>

<div class="content-grid">
    <section class="panel">
        <h2 class="h4 mb-3">Bot status</h2>
        <p><strong>Enabled:</strong> @(Model.BotEnabled ? "Yes" : "No")</p>
        <p><strong>Bot token configured:</strong> @(Model.HasBotToken ? "Yes" : "No")</p>
        <p><strong>Status:</strong> @Model.BotStatusMessage</p>

        @if (Model.BotProfile is not null)
        {
            <hr />
            <p><strong>Bot name:</strong> @Model.BotProfile.FirstName</p>
            <p><strong>Username:</strong> @@@Model.BotProfile.Username</p>
            <p><strong>Can join groups:</strong> @(Model.BotProfile.CanJoinGroups == true ? "Yes" : "No / Unknown")</p>
        }
    </section>

    <section class="panel">
        <h2 class="h4 mb-3">Onboarding steps</h2>
        <ol>
            <li>Use <code>BotFather</code> in Telegram to create a bot and copy the token.</li>
            <li>Set secrets: <code>dotnet user-secrets set "TelegramBot:Enabled" "true"</code> and <code>dotnet user-secrets set "TelegramBot:BotToken" "your-bot-token"</code>.</li>
            <li>Start the app with <code>Run-Local.cmd</code> or <code>dotnet run</code>.</li>
            <li>Open Telegram and try <code>/today</code>, <code>/today_best</code>, <code>/team 兄弟</code>, <code>/follow 樂天</code>, or <code>/recap</code>.</li>
            <li>The inline buttons are intentionally small now: today, today_best, my_follow, news, recap, help.</li>
            <li>After the first message arrives, the chat should appear below and in the Telegram Chats admin page.</li>
        </ol>
    </section>
</div>

<section class="panel mt-4">
    <h2 class="h4 mb-3">Recent chats detected by the bot</h2>

    @if (Model.RecentChats.Count == 0)
    {
        <p class="mb-0">目前還沒有記錄到任何 Telegram chat，先傳一則訊息給 bot 就可以了。</p>
    }
    else
    {
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th>Chat Title</th>
                    <th>Chat Id</th>
                    <th>Tracked Team</th>
                    <th>Updated</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var chat in Model.RecentChats)
            {
                <tr>
                    <td>@chat.ChatTitle</td>
                    <td><code>@chat.ChatId</code></td>
                    <td>@Model.GetFollowedTeamLabel(chat)</td>
                    <td>@chat.LastUpdatedTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>
