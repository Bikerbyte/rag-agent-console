@page
@model SecurityAdvisoryBot.Pages.Telegram.IndexModel
@{
    ViewData["Title"] = "Telegram";
}

<section class="page-header">
    <div>
        <p class="eyebrow">Bot settings</p>
        <h1>Telegram bot</h1>
        <p class="page-copy">檢查 bot 設定、連線狀態與最近偵測到的聊天</p>
    </div>
</section>

<section class="content-grid">
    <article class="panel">
        <div class="panel-header">
            <div class="panel-title-group">
                <span class="section-kicker">狀態</span>
                <h2 class="panel-title">Bot 狀態</h2>
                <p class="panel-subtitle">先確認 Telegram API 連線正常</p>
            </div>
        </div>

        <div class="mini-grid">
            <div class="mini-stat">
                <span>啟用</span>
                <strong>@(Model.BotEnabled ? "是" : "否")</strong>
            </div>
            <div class="mini-stat">
                <span>Token</span>
                <strong>@(Model.HasBotToken ? "已設定" : "未設定")</strong>
            </div>
            <div class="mini-stat">
                <span>連線</span>
                <strong>@Model.BotStatusMessage</strong>
            </div>
        </div>

        @if (Model.BotProfile is not null)
        {
            <div class="detail-stack">
                <div class="detail-row">
                    <strong>Bot 名稱</strong>
                    <p class="muted-line">@Model.BotProfile.FirstName</p>
                </div>
                <div class="detail-row">
                    <strong>帳號</strong>
                    <p class="muted-line">@("@")@Model.BotProfile.Username</p>
                </div>
                <div class="detail-row">
                    <strong>可加入群組</strong>
                    <p class="muted-line">@(Model.BotProfile.CanJoinGroups == true ? "是" : "否 / 未知")</p>
                </div>
            </div>
        }
    </article>

    <article class="panel">
        <div class="panel-header">
            <div class="panel-title-group">
                <span class="section-kicker">設定流程</span>
                <h2 class="panel-title">快速開始</h2>
                <p class="panel-subtitle">讓 bot 先能收訊息，再打開通知</p>
            </div>
        </div>

        <ol class="panel-list">
            <li>用 <code>BotFather</code> 建立 bot 並取得 token</li>
            <li>設定 <code>TelegramBot:Enabled</code> 與 <code>TelegramBot:BotToken</code></li>
            <li>用 <code>dotnet run</code> 或 Docker Compose 啟動站台</li>
            <li>測試 <code>/latest</code>、<code>/critical</code>、<code>/kev</code>、<code>/ask 最近 Fortinet 有哪些風險？</code></li>
            <li>收到第一則訊息後，聊天會出現在下方與訂閱設定頁</li>
        </ol>
    </article>
</section>

<section class="panel mt-4">
    <div class="panel-header">
        <div class="panel-title-group">
            <span class="section-kicker">聊天紀錄</span>
            <h2 class="panel-title">最近偵測到的聊天</h2>
            <p class="panel-subtitle">bot 最近有看到哪些 Telegram chat</p>
        </div>
    </div>

    @if (Model.RecentChats.Count == 0)
    {
        <div class="empty-state">
            <p class="empty-copy">目前還沒有偵測到聊天，先傳一則訊息給 bot</p>
        </div>
    }
    else
    {
        <div class="table-section">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>聊天名稱</th>
                        <th>聊天 ID</th>
                        <th>弱點通知</th>
                        <th>弱點關鍵字</th>
                        <th>更新時間</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var chat in Model.RecentChats)
                {
                    <tr>
                        <td>
                            <span class="table-title">@chat.ChatTitle</span>
                        </td>
                        <td><code>@chat.ChatId</code></td>
                        <td>@(chat.EnableAdvisoryPush ? "啟用" : "停用")</td>
                        <td>@SecurityAdvisoryBot.Pages.Telegram.IndexModel.GetAdvisoryWatchlistLabel(chat)</td>
                        <td>@chat.LastUpdatedTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
