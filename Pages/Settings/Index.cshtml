@page
@using RagAgentConsole.Models
@model RagAgentConsole.Pages.Settings.IndexModel
@{
    ViewData["Title"] = L["設定"].Value;
}

<section class="page-header compact-header">
    <div>
        <p class="eyebrow">@L["應用設定"]</p>
        <h1>@L["設定"]</h1>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info" role="alert">@Model.StatusMessage</div>
}

<section class="panel settings-panel settings-workbench">
    <div class="settings-rail">
        <span class="section-kicker">@L["執行設定"]</span>
        <h2 class="panel-title">@L["設定狀態"]</h2>

        <div class="settings-status-card">
            <span class="metric-label">@L["AI 連線"]</span>
            <strong>@Model.AiStatusLabel</strong>
            <p>@Model.AiStatusDetail</p>
        </div>

        <div class="settings-status-card">
            <span class="metric-label">@L["向量資料庫"]</span>
            <strong>PgVector</strong>
        </div>

        <nav class="settings-anchor-nav" aria-label="Settings sections">
            <a href="#settings-agent">@L["Agent"]</a>
            <a href="#settings-ai">@L["AI 供應商"]</a>
            <a href="#settings-rag">RAG</a>
            <a href="#settings-telegram">Telegram</a>
            <a href="#settings-jobs">@L["背景工作"]</a>
        </nav>
    </div>

    <form method="post" asp-page-handler="Save" class="settings-editor">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <section class="settings-card" id="settings-agent">
            <div class="settings-card-header">
                <div>
                    <span class="section-kicker">Agent</span>
                    <h3>@L["Agent 識別與提示詞"]</h3>
                </div>
            </div>
            <div class="settings-control-grid">
                <label class="field-block">
                    <span>@L["Agent 名稱"]</span>
                    <input asp-for="Input.AgentName" class="form-control" placeholder="AI Assistant" />
                </label>
                <label class="field-block">
                    <span>@L["Agent 標語"]</span>
                    <input asp-for="Input.AgentTagline" class="form-control" placeholder="@Model.DefaultAgentOptions.AgentTagline" />
                </label>
                <label class="field-block field-span-2">
                    <span>@L["對話輸入提示"]</span>
                    <input asp-for="Input.ChatPlaceholder" class="form-control" placeholder="@Model.DefaultAgentOptions.ChatPlaceholder" />
                </label>
                <label class="field-block">
                    <span>@L["預設知識模組"]</span>
                    <select asp-for="Input.DefaultModule" class="form-select">
                        <option value="@KnowledgeModuleNames.InternalDocs">@KnowledgeModuleNames.InternalDocs</option>
                        <option value="@KnowledgeModuleNames.WorkflowQa">@KnowledgeModuleNames.WorkflowQa</option>
                    </select>
                </label>
                <div class="field-block field-span-2">
                    <div class="settings-prompt-header">
                        <span>@L["查詢規劃提示詞"]</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="resetPrompt('Input_PlannerSystemPrompt', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DefaultAgentOptions.PlannerSystemPrompt)))">@L["還原預設"]</button>
                    </div>
                    <textarea asp-for="Input.PlannerSystemPrompt" class="form-control" rows="6" placeholder="@Model.DefaultAgentOptions.PlannerSystemPrompt"></textarea>
                    <small>@L["決定要檢索什麼的系統提示詞；換領域時一併調整。"]</small>
                </div>
                <div class="field-block field-span-2">
                    <div class="settings-prompt-header">
                        <span>@L["RAG 系統提示詞"]</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="resetPrompt('Input_RagSystemPrompt', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DefaultAgentOptions.RagSystemPrompt)))">@L["還原預設"]</button>
                    </div>
                    <textarea asp-for="Input.RagSystemPrompt" class="form-control" rows="8" placeholder="@Model.DefaultAgentOptions.RagSystemPrompt"></textarea>
                    <small>@L["知識庫有命中時使用；留空則用內建預設。"]</small>
                </div>
                <div class="field-block field-span-2">
                    <div class="settings-prompt-header">
                        <span>@L["一般系統提示詞"]</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="resetPrompt('Input_GeneralSystemPrompt', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DefaultAgentOptions.GeneralSystemPrompt)))">@L["還原預設"]</button>
                    </div>
                    <textarea asp-for="Input.GeneralSystemPrompt" class="form-control" rows="5" placeholder="@Model.DefaultAgentOptions.GeneralSystemPrompt"></textarea>
                    <small>@L["用於問候語與沒有命中知識庫的查詢。"]</small>
                </div>
                <div class="field-block field-span-2">
                    <div class="settings-prompt-header">
                        <span>@L["無法回答時的回覆"]</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="resetPrompt('Input_UnavailableReply', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DefaultAgentOptions.UnavailableReply)))">@L["還原預設"]</button>
                    </div>
                    <textarea asp-for="Input.UnavailableReply" class="form-control" rows="4" placeholder="@Model.DefaultAgentOptions.UnavailableReply"></textarea>
                </div>
            </div>
        </section>

        <section class="settings-card is-primary" id="settings-ai">
            <div class="settings-card-header">
                <div>
                    <span class="section-kicker">@L["AI 供應商"]</span>
                    <h3>@L["模型與檢索執行"]</h3>
                </div>
                <span class="status-pill @Model.AiStatusClass">@Model.AiStatusLabel</span>
            </div>

            <div class="settings-control-grid">
                <label class="field-block field-span-2">
                    <span>@L["供應商"]</span>
                    <select asp-for="Input.AiProvider" class="form-select">
                        <option value="Local">@L["本機備援"]</option>
                        <option value="OpenAI">OpenAI</option>
                        <option value="Ollama">Ollama</option>
                    </select>
                </label>
                <label class="field-switch">
                    <input asp-for="Input.EnableChatGeneration" class="form-check-input" />
                    <span><strong>@L["回答生成"]</strong></span>
                </label>
                <label class="field-switch">
                    <input asp-for="Input.UseLocalFallback" class="form-check-input" />
                    <span><strong>@L["本機備援"]</strong></span>
                </label>
            </div>

            <div class="provider-grid">
                <div class="provider-box">
                    <div class="provider-box-header">
                        <strong>OpenAI</strong>
                        <span class="status-pill @(Model.HasOpenAiApiKey ? "is-success" : "is-neutral")">
                            @(Model.HasOpenAiApiKey ? L["已儲存金鑰"] : L["未設金鑰"])
                        </span>
                    </div>
                    <div class="settings-control-grid">
                        <label class="field-block field-span-2">
                            <span>@L["API 金鑰"]</span>
                            <input asp-for="Input.OpenAiApiKey" class="form-control" type="password" autocomplete="off"
                                   placeholder="@(Model.HasOpenAiApiKey ? IndexModel.SecretMask : string.Empty)" />
                            <span asp-validation-for="Input.OpenAiApiKey" class="text-danger"></span>
                        </label>
                        <label class="field-block field-span-2">
                            <span>Base URL</span>
                            <input asp-for="Input.OpenAiApiBaseUrl" class="form-control" />
                            <span asp-validation-for="Input.OpenAiApiBaseUrl" class="text-danger"></span>
                        </label>
                        <label class="field-block">
                            <span>@L["對話模型"]</span>
                            <input asp-for="Input.OpenAiChatModel" class="form-control" />
                            <span asp-validation-for="Input.OpenAiChatModel" class="text-danger"></span>
                        </label>
                        <label class="field-block">
                            <span>@L["向量模型"]</span>
                            <input asp-for="Input.OpenAiEmbeddingModel" class="form-control" />
                            <span asp-validation-for="Input.OpenAiEmbeddingModel" class="text-danger"></span>
                        </label>
                    </div>
                </div>

                <div class="provider-box">
                    <div class="provider-box-header">
                        <strong>Ollama</strong>
                        <span class="status-pill is-neutral">@L["本機端點"]</span>
                    </div>
                    <div class="settings-control-grid">
                        <label class="field-block field-span-2">
                            <span>Base URL</span>
                            <input asp-for="Input.OllamaApiBaseUrl" class="form-control" />
                            <span asp-validation-for="Input.OllamaApiBaseUrl" class="text-danger"></span>
                        </label>
                        <label class="field-block">
                            <span>@L["對話模型"]</span>
                            <input asp-for="Input.OllamaChatModel" class="form-control" />
                        </label>
                        <label class="field-block">
                            <span>@L["向量模型"]</span>
                            <input asp-for="Input.OllamaEmbeddingModel" class="form-control" />
                        </label>
                    </div>
                </div>
            </div>
        </section>

        <section class="settings-card" id="settings-rag">
            <div class="settings-card-header">
                <div>
                    <span class="section-kicker">RAG</span>
                    <h3>@L["檢索與可觀測性"]</h3>
                </div>
                <span class="status-pill is-success">PgVector</span>
            </div>

            <div class="settings-control-grid">
                <label class="field-block">
                    <span>@L["候選上限"]</span>
                    <input asp-for="Input.VectorStoreCandidateLimit" class="form-control" type="number" min="50" max="10000" />
                </label>
                <label class="field-block">
                    <span>@L["回答片段上限"]</span>
                    <input asp-for="Input.RagMaxChunks" class="form-control" type="number" min="1" max="20" />
                </label>
                <label class="field-block">
                    <span>@L["本機向量維度"]</span>
                    <input asp-for="Input.LocalEmbeddingDimensions" class="form-control" type="number" min="64" max="2048" />
                </label>
                <label class="field-switch">
                    <input asp-for="Input.EnableOpenTelemetry" class="form-check-input" />
                    <span><strong>OpenTelemetry</strong></span>
                </label>
                <label class="field-switch">
                    <input asp-for="Input.EnableOpenTelemetryConsoleExporter" class="form-check-input" />
                    <span><strong>Console exporter</strong></span>
                </label>
                <label class="field-block">
                    <span>@L["服務名稱"]</span>
                    <input asp-for="Input.OpenTelemetryServiceName" class="form-control" />
                </label>
            </div>
        </section>

        <section class="settings-card" id="settings-telegram">
            <div class="settings-card-header">
                <div>
                    <span class="section-kicker">Telegram</span>
                    <h3>@L["Bot 接入與 API"]</h3>
                </div>
                <span class="status-pill @(Model.BotEnabled && Model.HasTelegramBotToken ? "is-success" : "is-warning")">
                    @(Model.BotEnabled && Model.HasTelegramBotToken ? L["已設定"] : L["待設定"])
                </span>
            </div>

            <div class="settings-control-grid">
                <label class="field-switch field-span-2">
                    <input asp-for="Input.TelegramEnabled" class="form-check-input" />
                    <span><strong>@L["啟用 Telegram bot"]</strong></span>
                </label>
                <label class="field-block">
                    <span>@L["Bot token"] @(Model.HasTelegramBotToken ? L["（已儲存）"] : L["（未設定）"])</span>
                    <input asp-for="Input.TelegramBotToken" class="form-control" type="password" autocomplete="off"
                           placeholder="@(Model.HasTelegramBotToken ? IndexModel.SecretMask : string.Empty)" />
                </label>
                <label class="field-block">
                    <span>Telegram API base URL</span>
                    <input asp-for="Input.TelegramApiBaseUrl" class="form-control" />
                    <span asp-validation-for="Input.TelegramApiBaseUrl" class="text-danger"></span>
                </label>
                <label class="field-switch field-span-2">
                    <input asp-for="Input.UseWebhookMode" class="form-check-input" />
                    <span><strong>Webhook @L["模式"]</strong></span>
                </label>
                <label class="field-block">
                    <span>Webhook URL</span>
                    <input asp-for="Input.WebhookUrl" class="form-control" placeholder="https://your-domain/api/telegram/webhook" />
                </label>
                <label class="field-block">
                    <span>Webhook path</span>
                    <input asp-for="Input.WebhookPath" class="form-control" />
                </label>
                <label class="field-block">
                    <span>Webhook secret token</span>
                    <input asp-for="Input.WebhookSecretToken" class="form-control" type="password" autocomplete="off"
                           placeholder="@(Model.HasWebhookSecretToken ? IndexModel.SecretMask : string.Empty)" />
                </label>
                <label class="field-block">
                    <span>@L["輪詢間隔（秒）"]</span>
                    <input asp-for="Input.PollingDelaySeconds" class="form-control" type="number" min="1" />
                </label>
            </div>
        </section>

        <div class="settings-save-bar">
            <button type="submit" class="btn btn-primary">@L["儲存設定"]</button>
        </div>
    </form>
</section>

@section Scripts {
    <script>
        function resetPrompt(id, defaultValue) {
            const el = document.getElementById(id);
            if (el) { el.value = defaultValue; }
        }
    </script>
}
