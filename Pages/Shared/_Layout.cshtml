@using SecurityAdvisoryBot.Models
@using SecurityAdvisoryBot.Services
@using Microsoft.Extensions.Options
@inject IOptions<AppRuntimeOptions> AppRuntimeOptions
@inject IAppSettingsService AppSettingsService
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var currentInstanceName = AppRuntimeOptions.Value.InstanceName;
    var layoutAgentOptions = await AppSettingsService.GetAgentOptionsAsync(Context.RequestAborted);
    var layoutAgentName = layoutAgentOptions.AgentName;
    var layoutAgentTagline = layoutAgentOptions.AgentTagline;
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @layoutAgentName</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+TC:wght@400;500;600;700&family=Noto+Serif+TC:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="app-sidebar">
            <a class="app-brand" asp-area="" asp-page="/Index">
                <span class="app-brand-mark">R</span>
                <span class="app-brand-copy">
                    <strong>@layoutAgentName</strong>
                    <span>@layoutAgentTagline</span>
                </span>
            </a>

            <nav class="app-nav" aria-label="Primary">
                <a class="app-nav-link @(currentPage == "/Index" ? "is-active" : string.Empty)" asp-area="" asp-page="/Index">
                    <span class="app-nav-eyebrow">Overview</span>
                    <strong>Dashboard</strong>
                </a>
                <a class="app-nav-link @(currentPage == "/Advisories/Index" ? "is-active" : string.Empty)" asp-area="" asp-page="/Advisories/Index">
                    <span class="app-nav-eyebrow">RAG data</span>
                    <strong>Knowledge Base</strong>
                </a>
                <a class="app-nav-link @(currentPage == "/Chat/Index" ? "is-active" : string.Empty)" asp-area="" asp-page="/Chat/Index">
                    <span class="app-nav-eyebrow">Agent</span>
                    <strong>Chat</strong>
                </a>
                <a class="app-nav-link @(currentPage == "/Operations/Index" ? "is-active" : string.Empty)" asp-area="" asp-page="/Operations/Index">
                    <span class="app-nav-eyebrow">Runtime</span>
                    <strong>Operations</strong>
                </a>
                <a class="app-nav-link @(currentPage == "/Operations/Evaluation" ? "is-active" : string.Empty)" asp-area="" asp-page="/Operations/Evaluation">
                    <span class="app-nav-eyebrow">RAG quality</span>
                    <strong>Evaluation</strong>
                </a>
                <a class="app-nav-link @(currentPage == "/Settings/Index" ? "is-active" : string.Empty)" asp-area="" asp-page="/Settings/Index">
                    <span class="app-nav-eyebrow">Config</span>
                    <strong>Settings</strong>
                </a>
            </nav>

            <section class="sidebar-note">
                <span class="topbar-chip">TEAM</span>
                <span class="user-avatar">I</span>
                <span>Ian</span>
            </section>
        </header>

        <div class="app-main">
            <header class="app-topbar">
                <div>
                    <p class="topbar-label">@layoutAgentName</p>
                    <h1 class="topbar-title">@ViewData["Title"]</h1>
                </div>
                <div class="topbar-meta">
                    <span class="topbar-chip">Node: @currentInstanceName</span>
                </div>
            </header>

            <main role="main" class="app-content">
                @RenderBody()
            </main>

            <footer class="app-footer">
                <span>@layoutAgentName</span>
                <span>@layoutAgentTagline</span>
            </footer>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
