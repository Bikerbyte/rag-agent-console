@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CPBL Telegram 助手</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+TC:wght@400;500;600;700&family=Noto+Serif+TC:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CPBLLineBotCloud.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="app-sidebar">
            <a class="app-brand" asp-area="" asp-page="/Index">
                <span class="app-brand-mark">CPBL</span>
                <span class="app-brand-copy">
                    <strong>Telegram 助手</strong>
                    <span>賽程查詢、群組通知、同步作業與 bot 狀態管理台</span>
                </span>
            </a>

            <nav class="app-nav" aria-label="Primary">
                <a class="app-nav-link @(currentPage == "/Index" ? "is-active" : string.Empty)" asp-area="" asp-page="/Index">
                    <span class="app-nav-eyebrow">總覽</span>
                    <strong>首頁</strong>
                </a>
                <a class="app-nav-link @(currentPage == "/Telegram/Index" ? "is-active" : string.Empty)" asp-area="" asp-page="/Telegram/Index">
                    <span class="app-nav-eyebrow">Bot</span>
                    <strong>Telegram</strong>
                </a>
                <a class="app-nav-link @(currentPage == "/Games/Index" ? "is-active" : string.Empty)" asp-area="" asp-page="/Games/Index">
                    <span class="app-nav-eyebrow">賽程</span>
                    <strong>比賽</strong>
                </a>
                <a class="app-nav-link @(currentPage == "/News/Index" ? "is-active" : string.Empty)" asp-area="" asp-page="/News/Index">
                    <span class="app-nav-eyebrow">內容</span>
                    <strong>新聞</strong>
                </a>
                <a class="app-nav-link @(currentPage == "/Groups/Index" ? "is-active" : string.Empty)" asp-area="" asp-page="/Groups/Index">
                    <span class="app-nav-eyebrow">推播</span>
                    <strong>聊天設定</strong>
                </a>
                <a class="app-nav-link @(currentPage == "/Logs/Index" ? "is-active" : string.Empty)" asp-area="" asp-page="/Logs/Index">
                    <span class="app-nav-eyebrow">紀錄</span>
                    <strong>紀錄</strong>
                </a>
            </nav>

            <section class="sidebar-note">
                <p class="sidebar-note-label">目前重點</p>
                <p class="sidebar-note-text">先把 bot 維持穩定，讓日常查球、看 log、調群組設定都能一眼看懂。</p>
            </section>
        </aside>

        <div class="app-main">
            <header class="app-topbar">
                <div>
                    <p class="topbar-label">CPBL Bot Console</p>
                    <h1 class="topbar-title">@ViewData["Title"]</h1>
                </div>
                <div class="topbar-meta">
                    <span class="topbar-chip">ASP.NET Core Razor Pages</span>
                    <span class="topbar-chip">CPBL Data Sync</span>
                    <span class="topbar-chip">Telegram Delivery</span>
                </div>
            </header>

            <main role="main" class="app-content">
                @RenderBody()
            </main>

            <footer class="app-footer">
                <span>CPBL Telegram 助手</span>
                <span>給日常查球和群組提醒用的實作型 side project</span>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
