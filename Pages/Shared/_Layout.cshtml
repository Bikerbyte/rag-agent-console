@using System.Globalization
@using RagAgentConsole.Models
@using RagAgentConsole.Services
@using Microsoft.Extensions.Options
@inject IOptions<AppRuntimeOptions> AppRuntimeOptions
@inject IAppSettingsService AppSettingsService
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var currentInstanceName = AppRuntimeOptions.Value.InstanceName;
    var layoutAgentOptions = await AppSettingsService.GetAgentOptionsAsync(Context.RequestAborted);
    var layoutAgentName = layoutAgentOptions.AgentName;
    var layoutAgentTagline = layoutAgentOptions.AgentTagline;
    var isEnglish = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en";
    var returnPath = Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString);
    string NavClass(string page) => currentPage == page ? "app-nav-link is-active" : "app-nav-link";
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · @layoutAgentName</title>
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" sizes="any" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+TC:wght@400;500;600;700&family=Noto+Serif+TC:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="app-sidebar">
            <a class="app-brand" asp-area="" asp-page="/Index">
                <span class="app-brand-mark">@(layoutAgentName.Length > 0 ? char.ToUpperInvariant(layoutAgentName[0]) : 'R')</span>
                <span class="app-brand-copy">
                    <strong>@layoutAgentName</strong>
                    <span>@layoutAgentTagline</span>
                </span>
            </a>

            <nav class="app-nav" aria-label="Primary">
                <a class="@NavClass("/Index")" asp-area="" asp-page="/Index">
                    <span class="app-nav-icon">▦</span><span>@L["儀表板"]</span>
                </a>
                <a class="@NavClass("/Advisories/Index")" asp-area="" asp-page="/Advisories/Index">
                    <span class="app-nav-icon">▤</span><span>@L["知識庫"]</span>
                </a>
                <a class="@NavClass("/Chat/Index")" asp-area="" asp-page="/Chat/Index">
                    <span class="app-nav-icon">◍</span><span>@L["對話"]</span>
                </a>
                <a class="@NavClass("/Operations/Index")" asp-area="" asp-page="/Operations/Index">
                    <span class="app-nav-icon">◆</span><span>@L["運行狀態"]</span>
                </a>
                <a class="@NavClass("/Operations/Evaluation")" asp-area="" asp-page="/Operations/Evaluation">
                    <span class="app-nav-icon">◎</span><span>@L["檢索評估"]</span>
                </a>
                <a class="@NavClass("/Settings/Index")" asp-area="" asp-page="/Settings/Index">
                    <span class="app-nav-icon">⚙</span><span>@L["設定"]</span>
                </a>
            </nav>

            <div class="app-sidebar-footer">
                <div class="lang-toggle" role="group" aria-label="Language">
                    <a class="lang-btn @(isEnglish ? string.Empty : "is-active")" href="/set-culture?culture=zh-Hant&returnUrl=@returnPath">中文</a>
                    <a class="lang-btn @(isEnglish ? "is-active" : string.Empty)" href="/set-culture?culture=en&returnUrl=@returnPath">EN</a>
                </div>
                <div class="sidebar-user">
                    <span class="user-avatar">@(layoutAgentName.Length > 0 ? char.ToUpperInvariant(layoutAgentName[0]) : 'A')</span>
                    <div>
                        <strong>@layoutAgentName</strong>
                        <span>@L["節點"]: @currentInstanceName</span>
                    </div>
                </div>
            </div>
        </aside>

        <div class="app-main">
            <main role="main" class="app-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
