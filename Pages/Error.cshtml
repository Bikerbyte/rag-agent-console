@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<section class="page-header">
    <div>
        <p class="eyebrow">Error</p>
        <h1>Request Failed</h1>
    </div>
</section>

<section class="content-grid">
    <article class="panel">
        <div class="panel-header">
            <div class="panel-title-group">
                <span class="section-kicker">排查</span>
                <h2 class="panel-title">Request 資訊</h2>
                <p class="panel-subtitle">先看 request id</p>
            </div>
        </div>

        @if (Model.ShowRequestId)
        {
            <div class="detail-row">
                <strong>Request ID</strong>
                <p class="muted-line"><code>@Model.RequestId</code></p>
            </div>
        }
        else
        {
            <p class="muted-line">這次錯誤沒有 request id</p>
        }
    </article>

    <article class="panel">
        <div class="panel-header">
            <div class="panel-title-group">
                <span class="section-kicker">Development</span>
                <h2 class="panel-title">詳細錯誤只留在本機</h2>
                <p class="panel-subtitle">正式環境不要開</p>
            </div>
        </div>

        <ul class="panel-list">
            <li>需要完整例外資訊時，再在本機啟用 <code>Development</code></li>
            <li>正式環境不要暴露詳細錯誤頁，避免洩漏敏感資訊</li>
            <li>重現問題後，再對照 request id 與最近 log</li>
        </ul>
    </article>
</section>
