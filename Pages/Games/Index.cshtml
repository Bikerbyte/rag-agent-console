@page
@model CPBLLineBotCloud.Pages.Games.IndexModel
@{
    ViewData["Title"] = "比賽";
}

<section class="page-header">
    <div>
        <p class="eyebrow">賽程資料</p>
        <h1>比賽</h1>
        <p class="page-copy">查看 bot 目前使用的賽程與比分資料</p>
    </div>
    <div class="page-actions">
        <form method="post" asp-page-handler="Sync">
            <button class="btn btn-primary" type="submit">立即同步</button>
        </form>
    </div>
</section>

<section class="panel">
        <div class="panel-header">
            <div class="panel-title-group">
                <span class="section-kicker">賽程表</span>
                <h2 class="panel-title">官方比賽資料</h2>
                <p class="panel-subtitle">確認資料是否同步成功即可</p>
            </div>
        </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-info">@Model.StatusMessage</div>
    }

    <div class="table-section">
        <table class="table admin-table">
            <thead>
                <tr>
                    <th>日期</th>
                    <th>時間</th>
                    <th>對戰</th>
                    <th>狀態</th>
                    <th>比分</th>
                    <th>球場</th>
                    <th>更新時間</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Games.Count == 0)
            {
                <tr>
                    <td colspan="7">
                        <div class="empty-state">
                            <p class="empty-copy">目前還沒有比賽資料</p>
                        </div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var game in Model.Games)
                {
                    <tr>
                        <td>@game.GameDate</td>
                        <td>@(game.StartTime?.ToString("HH:mm") ?? "--:--")</td>
                        <td>
                            <span class="table-title">@game.Matchup</span>
                        </td>
                        <td>@game.Status</td>
                        <td>@game.Score</td>
                        <td>@game.Venue</td>
                        <td>@game.LastUpdatedTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>
