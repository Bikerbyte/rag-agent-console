@page
@model RagAgentConsole.Pages.Operations.IndexModel
@{
    ViewData["Title"] = L["運行狀態"].Value;
}

<section class="page-header compact-header">
    <div><p class="eyebrow">@L["執行與通道"]</p><h1>@L["運行狀態"]</h1></div>
    <a class="btn btn-primary" asp-page="/Chat/Index">@L["開啟對話"]</a>
</section>

<section class="compact-metrics">
    <article class="metric-strip"><span class="metric-label">Telegram</span><strong>@(Model.BotEnabled && Model.HasBotToken ? L["就緒"].Value : L["待設定"].Value)</strong><p>@Model.PendingUpdateCount @L["筆待處理更新"]</p></article>
    <article class="metric-strip"><span class="metric-label">@L["節點"]</span><strong>@Model.InstanceName</strong></article>
    <article class="metric-strip"><span class="metric-label">@L["AI 供應商"]</span><strong>@Model.AiProviderText</strong><p>@(Model.IsAiChatEnabled ? L["已啟用回答生成"].Value : L["尚未連接回答生成"].Value)</p></article>
</section>

<section class="ops-grid">
    <article class="panel">
        <div class="panel-header"><div class="panel-title-group"><span class="section-kicker">Telegram</span><h2 class="panel-title">@L["連線狀態"]</h2></div></div>
        <div class="detail-stack"><div class="detail-row"><strong>@Model.BotStatusMessage</strong>@if (Model.BotProfile is not null) { <p class="muted-line">ID @Model.BotProfile.Id</p> }</div></div>
    </article>
    <article class="panel">
        <div class="panel-header"><div class="panel-title-group"><span class="section-kicker">@L["最近對話"]</span><h2 class="panel-title">Telegram chats</h2></div></div>
        <div class="compact-list">
        @if (Model.Chats.Count == 0) { <p class="empty-copy">@L["尚無 Telegram 對話。"]</p> }
        else { @foreach (var chat in Model.Chats) { <div class="compact-row"><div><span class="table-title">@chat.ChatTitle</span><p class="table-copy"><code>@chat.ChatId</code> · @chat.LastUpdatedTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p></div></div> } }
        </div>
    </article>
</section>

<section class="ops-grid mt-4">
    <article class="panel">
        <div class="panel-header"><div class="panel-title-group"><span class="section-kicker">@L["近期活動"]</span><h2 class="panel-title">@L["Telegram 傳送紀錄"]</h2></div></div>
        <div class="activity-stack">
        @if (Model.DeliveryLogs.Count == 0) { <p class="empty-copy">@L["尚無紀錄。"]</p> }
        else { @foreach (var log in Model.DeliveryLogs) { <div class="activity-row"><span class="status-pill @(log.IsSuccess ? "is-success" : "is-danger")">@(log.IsSuccess ? L["成功"] : L["失敗"])</span><div><strong>@log.MessageTitle</strong><p>@log.CreatedTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm") · @log.PushType @if (!log.IsSuccess) { <span>· @log.ErrorMessage</span> }</p></div></div> } }
        </div>
    </article>
</section>
