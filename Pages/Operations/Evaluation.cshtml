@page
@model SecurityAdvisoryBot.Pages.Operations.EvaluationModel
@{
    ViewData["Title"] = L["檢索評估"].Value;
}

<section class="page-header compact-header">
    <div>
        <p class="eyebrow">@L["RAG 品質"]</p>
        <h1>@L["檢索評估"]</h1>
        <p class="lede">@L["用 golden set 對每種檢索策略計算 Hit@1、Hit@5 與 MRR。"]</p>
    </div>
    <form method="post" asp-page-handler="Run">
        <button type="submit" class="btn btn-primary">@L["執行評估"]</button>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning" role="alert">@Model.ErrorMessage</div>
}

@if (Model.Report is { } report)
{
    <section class="eval-summary-grid">
        @foreach (var summary in report.Summaries)
        {
            <article class="eval-score-card">
                <header>
                    <span class="metric-label">@summary.RetrievalMode</span>
                    <span class="eval-n">N = @summary.CaseCount</span>
                </header>
                <div class="eval-score-row">
                    <div class="eval-score">
                        <span>Hit@1</span>
                        <strong class="@Model.ModeStatusClass(summary.HitAt1)">@Model.FormatPercent(summary.HitAt1)</strong>
                    </div>
                    <div class="eval-score">
                        <span>Hit@5</span>
                        <strong class="@Model.ModeStatusClass(summary.HitAt5)">@Model.FormatPercent(summary.HitAt5)</strong>
                    </div>
                    <div class="eval-score">
                        <span>MRR</span>
                        <strong>@Model.FormatMrr(summary.MeanReciprocalRank)</strong>
                    </div>
                </div>
            </article>
        }
    </section>
    <p class="eval-ranat">@L["完成於"] @report.RanAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</p>
}

<section class="panel">
    <div class="panel-header">
        <div>
            <span class="section-kicker">Golden set</span>
            <h2 class="panel-title">@Model.Cases.Count @L["個評估案例"]</h2>
            <p class="panel-subtitle">@L["每個案例要求預期的 CVE / 文件至少出現在前 5 筆結果中。"]</p>
        </div>
    </div>

    @if (Model.Cases.Count == 0)
    {
        <p>@L["沒有評估案例。請在"] <code>Evaluation/golden-set.json</code> @L["加入案例。"]</p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>@L["問題"]</th>
                    <th>@L["預期"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Cases)
                {
                    <tr>
                        <td><code>@item.Id</code></td>
                        <td>@item.Question</td>
                        <td>
                            @if (item.ExpectedCveIds.Count > 0)
                            {
                                <span>CVE: @string.Join(", ", item.ExpectedCveIds)</span>
                            }
                            @if (item.ExpectedDocumentTitles.Count > 0)
                            {
                                <span>@L["文件"]: @string.Join(", ", item.ExpectedDocumentTitles)</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@if (Model.Report is { } detailReport)
{
    @foreach (var summary in detailReport.Summaries)
    {
        <details class="eval-detail">
            <summary>@summary.RetrievalMode · @L["逐案明細"]</summary>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Case</th>
                        <th>@L["問題"]</th>
                        <th>Hit@1</th>
                        <th>Hit@5</th>
                        <th>@L["首個命中名次"]</th>
                        <th>@L["最佳結果"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var caseResult in summary.CaseResults)
                    {
                        var top = caseResult.TopResults.FirstOrDefault();
                        <tr>
                            <td><code>@caseResult.Case.Id</code></td>
                            <td>@caseResult.Case.Question</td>
                            <td>@(caseResult.HitAt1 ? "✓" : "—")</td>
                            <td>@(caseResult.HitAt5 ? "✓" : "—")</td>
                            <td>@(caseResult.FirstRelevantRank?.ToString() ?? "—")</td>
                            <td>
                                @if (top is not null)
                                {
                                    <div><strong>@top.Title</strong> @(top.IsRelevant ? "✓" : "")</div>
                                    <small>score=@top.Score.ToString("0.00") · v=@top.VectorScore.ToString("0.00") · t=@top.TextScore.ToString("0.00")</small>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </details>
    }
}
