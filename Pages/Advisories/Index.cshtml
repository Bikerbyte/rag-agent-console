@page
@using SecurityAdvisoryBot.Models
@model SecurityAdvisoryBot.Pages.Advisories.IndexModel
@{
    ViewData["Title"] = L["知識庫"].Value;
    var activeQuery = Request.Query["q"].ToString();
    var activeRetrievalQuery = Request.Query["retrievalQuery"].ToString();
    var activeRetrievalModule = Request.Query["retrievalModule"].ToString();
    var activeRetrievalMode = RetrievalModes.Normalize(Request.Query["retrievalMode"].ToString());
    var activeTopK = int.TryParse(Request.Query["topK"], out var parsedTopK) ? Math.Clamp(parsedTopK, 1, 10) : 5;
    var kevActive = string.Equals(Request.Query["kev"], "true", StringComparison.OrdinalIgnoreCase);
    var criticalActive = string.Equals(Request.Query["critical"], "true", StringComparison.OrdinalIgnoreCase);
    var requestedSection = Request.Query["section"].ToString();
    var activeSection = requestedSection is "sources" or "retrieval" or "settings" ? requestedSection : "documents";
    var sectionTitle = activeSection switch
    {
        "sources" => L["匯入來源"].Value,
        "retrieval" => L["檢索測試"].Value,
        "settings" => L["索引設定"].Value,
        _ => L["文件"].Value
    };
    var sectionSummary = activeSection switch
    {
        "sources" => L["同步內建範例連接器，或上傳你自己的文件。"].Value,
        "retrieval" => L["先確認知識庫命中的片段，再交給 Agent 產生回答。"].Value,
        "settings" => L["檢視 chunk、embedding 與檢索策略。"].Value,
        _ => L["管理上傳的文件與範例連接器資料。"].Value
    };
}

<section class="knowledge-shell">
    <aside class="knowledge-sidebar" aria-label="Knowledge sections">
        <div class="knowledge-space-card">
            <span class="knowledge-avatar">@(Model.AgentName.Length > 0 ? Model.AgentName[0] : 'A')</span>
            <div>
                <strong>@Model.AgentName</strong>
                <p>@L["知識庫"]</p>
            </div>
        </div>

        <nav class="knowledge-section-nav">
            <a class="knowledge-section-link @(activeSection == "documents" ? "is-active" : string.Empty)" asp-page="/Advisories/Index" asp-route-section="documents">
                <span>▣</span>
                <strong>@L["文件"]</strong>
            </a>
            <a class="knowledge-section-link @(activeSection == "sources" ? "is-active" : string.Empty)" asp-page="/Advisories/Index" asp-route-section="sources">
                <span>＋</span>
                <strong>@L["匯入來源"]</strong>
            </a>
            <a class="knowledge-section-link @(activeSection == "retrieval" ? "is-active" : string.Empty)" asp-page="/Advisories/Index" asp-route-section="retrieval">
                <span>◎</span>
                <strong>@L["檢索測試"]</strong>
            </a>
            <a class="knowledge-section-link @(activeSection == "settings" ? "is-active" : string.Empty)" asp-page="/Advisories/Index" asp-route-section="settings">
                <span>⚙</span>
                <strong>@L["索引設定"]</strong>
            </a>
        </nav>

        <div class="knowledge-sidebar-stats">
            <div>
                <strong>@Model.ManagedDocumentCount.ToString("N0")</strong>
                <span>@L["文件"]</span>
            </div>
            <div>
                <strong>@Model.ChunkCount.ToString("N0")</strong>
                <span>@L["檢索片段"]</span>
            </div>
        </div>
    </aside>

    <main class="knowledge-workspace">
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="alert alert-info" role="alert">@Model.StatusMessage</div>
        }

        <header class="knowledge-workspace-header">
            <div>
                <h1>@sectionTitle</h1>
                <p>@sectionSummary</p>
            </div>
            <div class="knowledge-header-actions">
                <a class="btn btn-outline-secondary" asp-page="/Advisories/Index" asp-route-section="retrieval">@L["檢索測試"]</a>
                <a class="btn btn-primary" asp-page="/Advisories/Index" asp-route-section="sources">@L["新增文件"]</a>
            </div>
        </header>

        @if (activeSection == "documents")
        {
            <section class="knowledge-content-grid">
                <div class="knowledge-primary-column">
                    <article class="knowledge-card">
                        <div class="knowledge-card-header">
                            <div>
                                <h2>@L["文件"]</h2>
                                <p>@L["點選任一文件即可在右側檢視內容範例。"]</p>
                            </div>
                            <a class="btn btn-sm btn-primary" asp-page="/Advisories/Index" asp-route-section="sources">@L["新增文件"]</a>
                        </div>

                        <div class="managed-document-list">
                            @if (Model.ManagedDocuments.Count == 0)
                            {
                                <p class="empty-copy">@L["尚未有任何文件。"]</p>
                            }
                            else
                            {
                                @foreach (var document in Model.ManagedDocuments)
                                {
                                    var isSelected = Model.SelectedDocument?.KnowledgeDocumentId == document.KnowledgeDocumentId;
                                    <article class="managed-document-row @(isSelected ? "is-selected" : string.Empty)">
                                        <a class="managed-document-main" asp-page="/Advisories/Index" asp-route-section="documents" asp-route-doc="@document.KnowledgeDocumentId">
                                            <strong>@document.Title</strong>
                                            <p>@document.ModuleName · @document.CharacterCount.ToString("N0") @L["字"] · @document.ChunkCount @L["片段"]</p>
                                        </a>
                                        <div class="document-actions">
                                            <span class="status-pill @(document.IsEnabled ? "is-success" : "is-neutral")">
                                                @(document.IsEnabled ? L["啟用"] : L["停用"])
                                            </span>
                                            <form method="post" asp-page-handler="ToggleDocument" asp-route-id="@document.KnowledgeDocumentId" asp-route-enabled="@(!document.IsEnabled)">
                                                <button class="icon-button" type="submit" title="@(document.IsEnabled ? L["停用"].Value : L["啟用"].Value)">@(document.IsEnabled ? "||" : ">")</button>
                                            </form>
                                            <form method="post" asp-page-handler="ReindexDocument" asp-route-id="@document.KnowledgeDocumentId">
                                                <button class="icon-button" type="submit" title="@L["重新索引"].Value">R</button>
                                            </form>
                                            <form method="post" asp-page-handler="DeleteDocument" asp-route-id="@document.KnowledgeDocumentId">
                                                <button class="icon-button is-danger" type="submit" title="@L["刪除"].Value">X</button>
                                            </form>
                                        </div>
                                    </article>
                                }
                            }
                        </div>
                    </article>

                    <article class="knowledge-card">
                        <div class="knowledge-card-header">
                            <div>
                                <h2>@L["範例連接器資料"]</h2>
                                <p>@L["內建 CISA KEV / NVD 作為範例領域，與上傳文件共用同一套 RAG 流程。"]</p>
                            </div>
                        </div>

                        <form class="knowledge-filter" method="get">
                            <input type="hidden" name="section" value="documents" />
                            <input class="form-control" type="search" name="q" placeholder="@L["搜尋範例資料 / 廠商 / 產品"].Value" value="@activeQuery" />
                            <label class="filter-chip @(kevActive ? "is-active" : string.Empty)">
                                <input type="checkbox" name="kev" value="true" checked="@kevActive" />
                                KEV
                            </label>
                            <label class="filter-chip @(criticalActive ? "is-active" : string.Empty)">
                                <input type="checkbox" name="critical" value="true" checked="@criticalActive" />
                                @L["高危"]
                            </label>
                            <button class="btn btn-outline-secondary" type="submit">@L["套用"]</button>
                        </form>

                        <div class="knowledge-table">
                            @if (Model.Advisories.Count == 0)
                            {
                                <div class="empty-state">
                                    <p class="empty-copy">@L["目前沒有符合條件的範例資料。可以先同步資料或調整搜尋條件。"]</p>
                                </div>
                            }
                            else
                            {
                                @foreach (var advisory in Model.Advisories.Take(10))
                                {
                                    var riskParts = new List<string>();
                                    if (!string.IsNullOrWhiteSpace(advisory.Severity))
                                    {
                                        riskParts.Add(advisory.Severity);
                                    }
                                    if (advisory.CvssScore.HasValue)
                                    {
                                        riskParts.Add($"CVSS {advisory.CvssScore:0.0}");
                                    }
                                    if (advisory.IsKnownExploited)
                                    {
                                        riskParts.Add("KEV");
                                    }

                                    <article class="advisory-row">
                                        <div>
                                            <strong>@(advisory.CveId ?? advisory.ExternalId)</strong>
                                            <p>@advisory.Title</p>
                                        </div>
                                        <span class="status-pill @(advisory.IsKnownExploited || advisory.CvssScore >= 9 ? "is-danger" : "is-neutral")">
                                            @(riskParts.Count == 0 ? L["未標示"].Value : string.Join(" / ", riskParts))
                                        </span>
                                    </article>
                                }
                            }
                        </div>
                    </article>
                </div>

                <aside class="knowledge-preview-panel" aria-label="Document preview">
                    @if (Model.SelectedDocument is { } selected)
                    {
                        <div class="doc-preview">
                            <div class="doc-preview-head">
                                <strong>@selected.Title</strong>
                                <span class="status-pill @(selected.IsEnabled ? "is-success" : "is-neutral")">
                                    @(selected.IsEnabled ? L["啟用"] : L["停用"])
                                </span>
                            </div>
                            <p class="doc-preview-meta">
                                @selected.ModuleName · @selected.SourceType · @selected.CharacterCount.ToString("N0") @L["字"] · @selected.ChunkCount @L["片段"]
                            </p>
                            <div class="doc-preview-sample">@Model.SelectedDocumentSample</div>
                            <p class="doc-preview-foot">@L["僅顯示前段內容範例。"]</p>
                        </div>
                    }
                    else
                    {
                        <div class="doc-preview is-empty">
                            <strong>@L["文件預覽"]</strong>
                            <p>@L["從左側選擇一份文件以檢視內容範例。"]</p>
                        </div>
                    }
                </aside>
            </section>
        }
        else if (activeSection == "sources")
        {
            <section class="knowledge-primary-column">
                <article class="knowledge-card">
                    <div class="knowledge-card-header">
                        <div>
                            <h2>@L["資料來源"]</h2>
                            <p>@L["同步內建範例，或上傳檔案建立你自己的知識庫。"]</p>
                        </div>
                    </div>

                    <div class="source-card-grid">
                        <article class="source-card is-active">
                            <span class="option-icon">C</span>
                            <div>
                                <strong>@L["資安範例連接器"]</strong>
                                <p>@L["從 CISA KEV / NVD 正規化公開資料，建立 CVE Advisory 範例模組。"]</p>
                            </div>
                            <form method="post" asp-page-handler="Sync">
                                <button class="btn btn-sm btn-primary" type="submit">@L["同步"]</button>
                            </form>
                        </article>

                        <article class="source-card">
                            <span class="option-icon">F</span>
                            <div>
                                <strong>@L["上傳檔案"]</strong>
                                <p>@L["支援 Markdown、TXT、HTML、CSV、DOCX，以開源套件解析。"]</p>
                            </div>
                        </article>
                    </div>
                </article>

                <article class="knowledge-card">
                    <div class="knowledge-card-header">
                        <div>
                            <h2>@L["上傳檔案"]</h2>
                            <p>@L["檔案會自動抽取、切塊、建立向量，並存成可檢索的文件。"]</p>
                        </div>
                    </div>

                    <form class="knowledge-ingest-form is-flat" method="post" asp-page-handler="UploadFile" enctype="multipart/form-data">
                        <div class="form-row">
                            <label class="field-block">
                                <span>@L["標題"]</span>
                                <input asp-for="FileInput.Title" class="form-control" placeholder="@L["新人政策、SOP、產品 FAQ"].Value" />
                            </label>
                            <label class="field-block">
                                <span>@L["模組"]</span>
                                <select asp-for="FileInput.ModuleName" class="form-select">
                                    <option value="@KnowledgeModuleNames.InternalDocs">@L["內部文件"]</option>
                                    <option value="@KnowledgeModuleNames.CveAdvisory">CVE Advisory</option>
                                    <option value="@KnowledgeModuleNames.WorkflowQa">@L["流程問答"]</option>
                                </select>
                            </label>
                        </div>
                        <div class="form-row">
                            <label class="field-block">
                                <span>@L["廠商"]</span>
                                <input asp-for="FileInput.Vendor" class="form-control" />
                            </label>
                            <label class="field-block">
                                <span>@L["產品"]</span>
                                <input asp-for="FileInput.Product" class="form-control" />
                            </label>
                        </div>
                        <label class="field-block">
                            <span>@L["標籤"]</span>
                            <input asp-for="FileInput.Tags" class="form-control" placeholder="hr, sop, product, faq" />
                        </label>
                        <label class="upload-zone">
                            <input asp-for="FileInput.Upload" type="file" accept=".md,.markdown,.txt,.log,.html,.htm,.csv,.docx" />
                            <strong>@L["選擇檔案"]</strong>
                            <span>@L["支援 Markdown、TXT、HTML、CSV、DOCX，上限 15 MB。"]</span>
                        </label>
                        <button class="btn btn-primary" type="submit">@L["匯入檔案"]</button>
                    </form>
                </article>
            </section>
        }
        else if (activeSection == "retrieval")
        {
            <section class="knowledge-primary-column">
                <article class="knowledge-card">
                    <div class="knowledge-card-header">
                        <div>
                            <h2>@L["檢索測試"]</h2>
                            <p>@L["輸入自然語言查詢，檢視會被當作 Agent context 的片段。"]</p>
                        </div>
                    </div>

                    <form class="retrieval-test-form is-flat" method="get">
                        <input type="hidden" name="section" value="retrieval" />
                        <label class="field-block">
                            <span>@L["查詢"]</span>
                            <input class="form-control" type="search" name="retrievalQuery" value="@activeRetrievalQuery" placeholder="@L["例如：遠端工作核准流程 或 最新 Cisco 風險"].Value" />
                        </label>
                        <label class="field-block">
                            <span>@L["模組"]</span>
                            <select class="form-select" name="retrievalModule">
                                <option value="" selected="@(string.IsNullOrWhiteSpace(activeRetrievalModule))">@L["全部模組"]</option>
                                <option value="@KnowledgeModuleNames.CveAdvisory" selected="@(activeRetrievalModule == KnowledgeModuleNames.CveAdvisory)">CVE Advisory</option>
                                <option value="@KnowledgeModuleNames.WorkflowQa" selected="@(activeRetrievalModule == KnowledgeModuleNames.WorkflowQa)">@L["流程問答"]</option>
                                <option value="@KnowledgeModuleNames.InternalDocs" selected="@(activeRetrievalModule == KnowledgeModuleNames.InternalDocs)">@L["內部文件"]</option>
                            </select>
                        </label>
                        <label class="field-block">
                            <span>@L["模式"]</span>
                            <select class="form-select" name="retrievalMode">
                                <option value="@RetrievalModes.Hybrid" selected="@(activeRetrievalMode == RetrievalModes.Hybrid)">@L["混合"]</option>
                                <option value="@RetrievalModes.Vector" selected="@(activeRetrievalMode == RetrievalModes.Vector)">@L["向量"]</option>
                                <option value="@RetrievalModes.Keyword" selected="@(activeRetrievalMode == RetrievalModes.Keyword)">@L["關鍵字"]</option>
                            </select>
                        </label>
                        <label class="field-block topk-field">
                            <span>Top K</span>
                            <input class="form-control" type="number" min="1" max="10" name="topK" value="@activeTopK" />
                        </label>
                        <button class="btn btn-primary" type="submit">@L["執行檢索"]</button>
                    </form>
                </article>

                @if (!string.IsNullOrWhiteSpace(Model.RetrievalError))
                {
                    <div class="alert alert-warning" role="alert">@Model.RetrievalError</div>
                }
                else if (!string.IsNullOrWhiteSpace(Model.RetrievalQuery) && Model.RetrievalResults.Count == 0)
                {
                    <div class="retrieval-empty">
                        <p>@L["目前沒有命中的片段。可以先同步範例資料、上傳文件，或改用更明確的關鍵字。"]</p>
                    </div>
                }
                else if (Model.RetrievalResults.Count > 0)
                {
                    <div class="retrieval-result-list">
                        @for (var index = 0; index < Model.RetrievalResults.Count; index++)
                        {
                            var result = Model.RetrievalResults[index];
                            <article class="retrieval-result-card">
                                <div class="retrieval-result-head">
                                    <div>
                                        <span class="chunk-rank"># @((index + 1).ToString("000"))</span>
                                        <strong>@(result.CveId ?? result.Title)</strong>
                                    </div>
                                    <span class="status-pill @(result.IsKnownExploited || result.CvssScore >= 9 ? "is-danger" : "is-neutral")">
                                        Score @FormatScore(result.Score)
                                    </span>
                                </div>
                                <p class="retrieval-title">@result.Title</p>
                                <dl class="retrieval-meta">
                                    <div>
                                        <dt>@L["模組"]</dt>
                                        <dd>@result.ModuleName</dd>
                                    </div>
                                    <div>
                                        <dt>Vector</dt>
                                        <dd>@FormatScore(result.VectorScore)</dd>
                                    </div>
                                    <div>
                                        <dt>Text</dt>
                                        <dd>@FormatScore(result.TextScore)</dd>
                                    </div>
                                </dl>
                                <p class="retrieval-chunk">@TrimPreview(result.ChunkText)</p>
                            </article>
                        }
                    </div>
                }
            </section>
        }
        else
        {
            <section class="knowledge-primary-column">
                <article class="knowledge-card">
                    <div class="knowledge-card-header">
                        <div>
                            <h2>@L["切塊與索引"]</h2>
                            <p>@L["範例資料與上傳文件都會自動切塊並建立向量索引。"]</p>
                        </div>
                    </div>

                    <div class="settings-readout">
                        <div class="readout-row">
                            <div>
                                <strong>@L["切塊方式"]</strong>
                                <p>@L["依結構化記錄或文件段落自動建立 chunk。"]</p>
                            </div>
                            <span class="status-pill is-success">@L["自動"]</span>
                        </div>
                        <div class="readout-row">
                            <div>
                                <strong>@L["索引模式"]</strong>
                                <p>@L["使用 provider embedding；無 API key 時自動切換本機備援。"]</p>
                            </div>
                            <span class="status-pill is-neutral">@Model.EstimatedTokenCount.ToString("N0") tokens</span>
                        </div>
                        <div class="readout-row">
                            <div>
                                <strong>@L["檢索策略"]</strong>
                                <p>@L["結合向量分數、BM25 關鍵字與模組過濾進行排序。"]</p>
                            </div>
                            <span class="status-pill is-neutral">Hybrid</span>
                        </div>
                    </div>
                </article>
            </section>
        }
    </main>
</section>

@functions {
    private static string TrimPreview(string value)
    {
        var compact = string.Join(' ', value.Split(new[] { '\r', '\n', '\t' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));
        return compact.Length <= 260 ? compact : compact[..260] + "...";
    }

    private static string FormatScore(double value)
        => value.ToString("0.000");
}
