@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="dashboard-hero compact-hero">
    <div>
        <p class="eyebrow">Security Advisory RAG Bot</p>
        <h1 class="display-title">CVE 弱點情報與 Telegram 通知管理</h1>
        <p class="dashboard-copy">
            提供弱點資料同步、RAG 索引、Telegram 通知與節點狀態的營運檢視。
        </p>
        <div class="hero-actions">
            <a class="btn btn-primary" asp-page="/Advisories/Index">Open knowledge base</a>
            <a class="btn btn-outline-secondary" asp-page="/Operations/Index">Bot operations</a>
        </div>
    </div>
</section>

<section class="compact-metrics">
    <article class="metric-strip">
        <span class="metric-label">Advisories</span>
        <strong>@Model.AdvisoryCount</strong>
        <p>@Model.KnownExploitedCount KEV · @Model.RagChunkCount RAG chunks</p>
    </article>
    <article class="metric-strip">
        <span class="metric-label">Telegram</span>
        <strong>@(Model.BotEnabled && Model.HasBotToken ? "Ready" : "Needs config")</strong>
        <p>@Model.ChatCount chats · @Model.PendingTelegramUpdateCount queued updates</p>
    </article>
    <article class="metric-strip">
        <span class="metric-label">AI provider</span>
        <strong>@Model.AiProviderText</strong>
        <p>OpenAI, Ollama, or local fallback</p>
    </article>
    <article class="metric-strip">
        <span class="metric-label">Runtime</span>
        <strong>@Model.InstanceName</strong>
        <p>@Model.ActiveNodeCount online node(s) · @Model.EnvironmentName</p>
    </article>
</section>

<section class="ops-grid mt-4">
    <article class="panel">
        <div class="panel-header">
            <div class="panel-title-group">
                <span class="section-kicker">Latest state</span>
                <h2 class="panel-title">RAG pipeline</h2>
            </div>
        </div>

        <div class="detail-stack">
            <div class="detail-row">
                <strong>Advisory sync</strong>
                <p class="muted-line">@Model.LatestAdvisorySyncText</p>
            </div>
            <div class="detail-row">
                <strong>Index</strong>
                <p class="muted-line">@Model.RagIndexText</p>
            </div>
            <div class="detail-row">
                <strong>Last Telegram delivery</strong>
                <p class="muted-line">@Model.LatestReplyText</p>
            </div>
        </div>
    </article>

    <article class="panel">
        <div class="panel-header">
            <div class="panel-title-group">
                <span class="section-kicker">Operations</span>
                <h2 class="panel-title">Command reference</h2>
            </div>
        </div>

        <ul class="panel-list">
            <li><code>CVE-2024-xxxx 有什麼風險？</code> 查詢單一 CVE</li>
            <li><code>最近 Cisco 有哪些高風險 CVE？</code> 查詢廠商弱點</li>
            <li><code>幫我追蹤 Fortinet Azure</code> 更新 Telegram watchlist</li>
            <li><code>dotnet run</code> 啟動站台和背景 worker</li>
        </ul>
    </article>
</section>
