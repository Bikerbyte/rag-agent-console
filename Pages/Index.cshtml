@page
@model IndexModel
@{
    ViewData["Title"] = L["儀表板"].Value;
}

<section class="dashboard-hero">
    <div>
        <p class="eyebrow">@Model.AgentTagline</p>
        <h1 class="display-title">@Model.AgentName</h1>
        <p class="dashboard-copy">
            @L["可換領域的 RAG Agent 平台：匯入文件、混合檢索、產生回答，並透過 Web 與 Telegram 對外服務。"]
        </p>
        <div class="hero-actions">
            <a class="btn btn-primary" asp-page="/Knowledge/Index">@L["開啟知識庫"]</a>
            <a class="btn btn-outline-secondary" asp-page="/Chat/Index">@L["開始對話"]</a>
        </div>
    </div>
</section>

<section class="compact-metrics">
    <article class="metric-strip">
        <span class="metric-label">@L["知識庫"]</span>
        <strong>@Model.DocumentCount.ToString("N0")</strong>
        <p>@Model.RagChunkCount.ToString("N0") @L["檢索片段"]</p>
    </article>
    <article class="metric-strip">
        <span class="metric-label">@L["AI 供應商"]</span>
        <strong>@Model.AiProviderText</strong>
        <p>@L["OpenAI、Ollama 或本機備援"]</p>
    </article>
    <article class="metric-strip">
        <span class="metric-label">@L["執行環境"]</span>
        <strong>@Model.InstanceName</strong>
        <p>@Model.EnvironmentName</p>
    </article>
</section>

<section class="panel">
    <div class="panel-header">
        <div class="panel-title-group">
            <span class="section-kicker">@L["最新狀態"]</span>
            <h2 class="panel-title">@L["RAG 流程現況"]</h2>
        </div>
        <a class="btn btn-sm btn-outline-secondary" asp-page="/Operations/Index">@L["前往運行狀態"]</a>
    </div>

    <div class="detail-stack">
        <div class="detail-row">
            <strong>@L["最近更新文件"]</strong>
            <p class="muted-line">@Model.LatestDocumentText</p>
        </div>
        <div class="detail-row">
            <strong>@L["索引"]</strong>
            <p class="muted-line">@Model.RagIndexText</p>
        </div>
        <div class="detail-row">
            <strong>@L["最近一次 Telegram 回覆"]</strong>
            <p class="muted-line">@Model.LatestReplyText</p>
        </div>
    </div>
</section>
