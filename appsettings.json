{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "TelegramBot": {
    "Enabled": false,
    "BotToken": "",
    "ApiBaseUrl": "https://api.telegram.org",
    "PollingDelaySeconds": 3,
    "UseWebhookMode": false,
    "WebhookPath": "/api/telegram/webhook",
    "WebhookUrl": "",
    "WebhookSecretToken": ""
  },
  "DataSources": {
    "AutoSyncIntervalMinutes": 15
  },
  "SecurityAdvisories": {
    "EnableCisaKevSource": true,
    "EnableNvdSource": true,
    "CisaKevJsonUrl": "https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json",
    "NvdApiBaseUrl": "https://services.nvd.nist.gov",
    "NvdLookbackDays": 7,
    "MaxNvdResultsPerSync": 100,
    "EmbeddingDimensions": 384,
    "RagMaxChunks": 5
  },
  "AiProvider": {
    "Provider": "Local",
    "EnableChatGeneration": false,
    "UseLocalFallback": true,
    "OpenAiApiBaseUrl": "https://api.openai.com",
    "OpenAiApiKey": "",
    "OpenAiChatModel": "gpt-4o-mini",
    "OpenAiEmbeddingModel": "text-embedding-3-small",
    "OllamaApiBaseUrl": "http://localhost:11434",
    "OllamaChatModel": "llama3.1",
    "OllamaEmbeddingModel": "nomic-embed-text",
    "ChatTimeoutSeconds": 45,
    "EmbeddingTimeoutSeconds": 45
  },
  "VectorStore": {
    "Provider": "EfJson",
    "CandidateLimit": 3000,
    "UseJsonFallback": true
  },
  "Observability": {
    "EnableOpenTelemetry": false,
    "EnableConsoleExporter": false,
    "OtlpEndpoint": "",
    "ServiceName": "RagAgentConsole"
  },
  "PushNotifications": {
    "Enabled": true,
    "EnableSecurityAdvisoryPush": true,
    "WorkerIntervalSeconds": 90,
    "AdvisoryLookbackHours": 72
  },
  "AppRuntime": {
    "InstanceName": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "AllowedHosts": "*"
}
